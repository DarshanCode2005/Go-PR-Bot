# LLM (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
# Nvidia NIM (free tier at https://build.nvidia.com — keys start with nvapi-)
NVIDIA_NIM_API_KEY=
# NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1/

# Model tiers (LiteLLM provider prefix required for non-OpenAI models)
# Examples:
#   GO_AGENT_MODEL_FAST=gemini/gemini-2.0-flash
#   GO_AGENT_MODEL_STRONG=gemini/gemini-2.0-flash
#   GO_AGENT_MODEL_FAST=groq/llama-3.3-70b-versatile
#   GO_AGENT_MODEL_FAST=nvidia_nim/meta/llama-3.1-8b-instruct
#   GO_AGENT_MODEL_STRONG=nvidia_nim/meta/llama-3.1-70b-instruct
# List available model IDs: curl -s https://integrate.api.nvidia.com/v1/models -H "Authorization: Bearer $NVIDIA_NIM_API_KEY"
GO_AGENT_MODEL_FAST=gpt-4o-mini
GO_AGENT_MODEL_STRONG=gpt-4o
# LLM retry knobs (rate-limit handling)
GO_AGENT_LLM_MAX_RETRIES=3
GO_AGENT_LLM_RETRY_BASE_DELAY=1.0

# GitHub (for issue fetch + PR create)
GITHUB_TOKEN=

# Runtime
GO_AGENT_WORK_DIR=./workspaces
GO_AGENT_ARTIFACTS_DIR=./artifacts
GO_AGENT_MAX_FIX_ITERATIONS=5
GO_AGENT_MAX_REVIEW_ROUNDS=1
GO_AGENT_MAX_ISSUE_COMMENTS=20
GO_AGENT_LOG_LEVEL=INFO

# Context bundle (issue + search → ranked files under char budget)
GO_AGENT_CONTEXT_MAX_CHARS=80000
GO_AGENT_CONTEXT_MAX_FILES=15
GO_AGENT_CONTEXT_GRAPH_MAX_HOPS=2
GO_AGENT_CONTEXT_SNIPPET_RADIUS=5
GO_AGENT_CONTEXT_FULL_FILE_TOP_K=3
GO_AGENT_CONTEXT_SUMMARY_TOP_K=5

# Optional RAG (semantic retrieval; requires: pip install -e ".[rag]")
# GO_AGENT_ENABLE_RAG=false
# GO_AGENT_RAG_TOP_K=10
# GO_AGENT_RAG_CHUNK_LINES=80
# GO_AGENT_RAG_CHUNK_OVERLAP=20
# GO_AGENT_RAG_EMBED_PROVIDER=local
# GO_AGENT_RAG_EMBED_MODEL=all-MiniLM-L6-v2
# GO_AGENT_RAG_MIN_SCORE=0.3

# Optional
# MEM0_API_KEY=
